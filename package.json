{
  "name": "@cloud-dog/tokens",
  "description": "Design tokens, shared assets, and theme primitives for Cloud-Dog web apps.",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "author": "Cloud-Dog, Viewdeck Engineering Limited",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://gitea.cloud-dog.net/api/packages/Cloud-Dog-External/npm/",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viewdeck/cloud-dog-ai.git",
    "directory": "cloud-dog-ai-ui-monorepo/packages/tokens"
  },
  "homepage": "https://cloud-dog.net",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "tailwindcss": "^3.4.10"
  },
  "devDependencies": {
    "css-tree": "^3.1.0"
  }
}
